rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Hackathon mode: open read/write for demo
    match /pricing_records/{doc} {
      allow read: if true;
      allow write: if true;
    }
    match /analysis_jobs/{doc} {
      allow read: if true;
      allow write: if true;
    }
    match /demo_products/{doc} {
      allow read: if true;
      allow write: if true;
    }
  }
}
